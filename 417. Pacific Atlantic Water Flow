class Solution {
public:
    void dfs(int i, int j, int prev ,vector<vector<int>>& sea, vector<vector<int>>& heights){
        int n = sea.size();
        int m = sea[0].size();
        
        if(i < 0 || j<0 || i >= n || j >= m || sea[i][j] == 1){
            return;
        }

        if(prev > heights[i][j]){
            return;
        }

        sea[i][j] = 1;

        dfs(i+1, j, heights[i][j], sea, heights);
        dfs(i-1, j, heights[i][j], sea, heights);
        dfs(i, j+1, heights[i][j], sea, heights);
        dfs(i, j-1, heights[i][j], sea, heights);
    }
    vector<vector<int>> pacificAtlantic(vector<vector<int>>& heights) {
        int n = heights.size();
        int m = heights[0].size();

        vector<vector<int>> pacific(n, vector<int>(m, 0));
        vector<vector<int>> atlantic(n, vector<int>(m, 0));

        for(int i =0;i<n;i++){
            dfs(i, 0, INT_MIN, pacific, heights);
            dfs(i, m-1, INT_MIN, atlantic, heights);
        }
        for(int j =0;j < m;j++){
            dfs(0, j, INT_MIN, pacific, heights);
            dfs(n-1, j, INT_MIN, atlantic, heights);
        }

        vector<vector<int>> answer;

        for(int i =0; i<n; i++){
            for(int j =0; j< m ; j++){
                if(atlantic[i][j] == 1 && pacific[i][j] == 1){
                    answer.push_back({i,j});
                }
            }
        }

        return answer;
    }
};
