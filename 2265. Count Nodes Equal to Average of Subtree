class Solution {
public:
    int answer;
    int traverse(TreeNode* root, int &count){
        if(root == nullptr){
            return 0;
        }
        count++;
        int sum = root->val + traverse(root->left, count) + traverse(root->right, count);
        return sum;
    }

    void traverseNodes(TreeNode* root){
        if(root == nullptr){
            return;
        }

        int count = 0; 
        int totalSum = traverse(root, count); 
        if((totalSum)/count == root->val) {
            answer++; 
        }
        traverseNodes(root->left); 
        traverseNodes(root->right);
    }
    int averageOfSubtree(TreeNode* root) {
        if(root == nullptr){
            return 0;
        }
        answer = 0;
        int count =0;
        traverseNodes(root);

        return answer;
    }
};




