/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
public:
    void findDir(TreeNode* root, int value, string &path, string &ans){
        if(root == nullptr || ans != ""){
            return;
        }

        if(root->val == value){
            ans = path;
            return;
        }

        path.push_back('L');
        findDir(root->left, value, path, ans);
        path.pop_back();

        path.push_back('R');
        findDir(root->right, value, path, ans);
        path.pop_back();
    }

    string getDirections(TreeNode* root, int startValue, int destValue) {
        string startPath = ""; 
        string path = "";
        findDir(root, startValue, path, startPath);
        string destPath = "";
        path = "";
        findDir(root, destValue, path, destPath);
        long long count =0;
        int i =0;
        while(i <startPath.size() && i < destPath.size()){
            if(startPath[i] == destPath[i]){
                count++;
            }
            else{
                break;
            }
            i++;
        }

        int startLen = startPath.substr(count).size();
        string s(startLen, 'U');
        s += destPath.substr(count);
        return s;
    }
};
