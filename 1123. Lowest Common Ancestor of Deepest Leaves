class Solution {
public:
    unordered_set<TreeNode*> deepestLeaves;

    void bfs(TreeNode* root){
        if(root == nullptr){
            return;
        }
        queue<TreeNode*> q;

        q.push(root);
        while(!q.empty()){
            int n = q.size();
            deepestLeaves.clear();
            while(n--){
                TreeNode* node = q.front();
                q.pop();
                if(node->left != nullptr){
                    q.push(node->left);
                } 
                if(node->right != nullptr){
                    q.push(node->right);
                } 
                deepestLeaves.insert(node);
            }
        }
    }

    TreeNode* findAncestor(TreeNode* root){
        if(root == nullptr){
            return nullptr;
        }
        TreeNode* leftChild = findAncestor(root->left);
        TreeNode* rightChild = findAncestor(root->right);
        
        if(deepestLeaves.find(root) != deepestLeaves.end()){
            return root;
        }

        if(leftChild && rightChild){
            return root;
        }
        return leftChild ? leftChild : rightChild;
    }
    TreeNode* lcaDeepestLeaves(TreeNode* root) {
        bfs(root);
        return findAncestor(root);
    }
};
