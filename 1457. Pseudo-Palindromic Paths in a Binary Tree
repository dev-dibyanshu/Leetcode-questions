class Solution {
public:
    int answer;
    void dfs(TreeNode* root, int count){
        if(root == nullptr){
            return;
        }

        count = count ^ (1 << root->val);

        if(root->left == nullptr && root->right == nullptr){
            if((count & (count-1)) == 0){
                answer++;
            }
        }
        dfs(root->left, count);
        dfs(root->right, count);
    }
    int pseudoPalindromicPaths (TreeNode* root) {
        answer =0;
        dfs(root, 0);
        return answer;
    }
};
